<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/vf_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center_horizontal"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_launcher_foreground" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:text="@string/setup_title"
            android:textColor="@color/vf_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp"
            android:text="@string/setup_subtitle"
            android:textColor="@color/vf_text_muted"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/langBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnLangBe"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="BY"
                android:textAllCaps="true"
                android:textColor="@color/vf_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnLangEn"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="EN"
                android:textAllCaps="true"
                android:textColor="@color/vf_text_muted"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnLangRu"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="RU"
                android:textAllCaps="true"
                android:textColor="@color/vf_text_muted"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvDilinkLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:gravity="center"
            android:text="@string/setup_dilink_label"
            android:textColor="@color/vf_text_muted"
            android:textSize="12sp" />

        <LinearLayout
            android:id="@+id/dilinkBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnDilinkAuto"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/setup_dilink_auto"
                android:textAllCaps="true"
                android:textColor="@color/vf_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnDilink3"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/setup_dilink_3"
                android:textAllCaps="true"
                android:textColor="@color/vf_text_muted"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnDilink5"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/setup_dilink_5"
                android:textAllCaps="true"
                android:textColor="@color/vf_text_muted"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardHud"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@color/vf_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setup_hud_title"
                android:textColor="@color/vf_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/setup_cluster_broadcast"
                android:textColor="@color/vf_text"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/setup_cluster_broadcast_hint"
                android:textColor="@color/vf_text_muted"
                android:textSize="12sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchClusterBroadcast"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:checked="true" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/setup_hint_yandex_turnhints"
                android:textColor="@color/vf_cyan"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardShizuku"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@color/vf_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setup_shizuku_title"
                android:textColor="@color/vf_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/setup_shizuku_body"
                android:textColor="@color/vf_text_muted"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnOpenShizuku"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/vf_card"
                android:text="@string/setup_btn_open_shizuku"
                android:textColor="@color/vf_text" />

            <Button
                android:id="@+id/btnShizukuGrant"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/vf_primary"
                android:text="@string/setup_btn_shizuku_grant"
                android:textColor="@color/vf_background" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardAdb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@color/vf_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setup_adb_title"
                android:textColor="@color/vf_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/setup_adb_body"
                android:textColor="@color/vf_text_muted"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvAdbCommand"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="monospace"
                android:textColor="@color/vf_cyan"
                android:textIsSelectable="true"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btnCopyAdb"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/vf_primary"
                android:text="@string/setup_btn_copy_adb"
                android:textColor="@color/vf_background" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardAccessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@color/vf_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setup_a11y_title"
                android:textColor="@color/vf_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/setup_a11y_body"
                android:textColor="@color/vf_text_muted"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnOpenAccessibility"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/vf_primary"
                android:text="@string/setup_btn_open_a11y"
                android:textColor="@color/vf_background" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTileAccessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@color/vf_card"
            android:padding="14dp"
            android:textColor="@color/vf_text"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvTileCapture"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@color/vf_card"
            android:padding="14dp"
            android:textColor="@color/vf_text"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvTileProjectMedia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@color/vf_card"
            android:padding="14dp"
            android:textColor="@color/vf_text"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvTileBackground"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@color/vf_card"
            android:padding="14dp"
            android:textColor="@color/vf_text"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnGrant"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/vf_primary"
            android:text="@string/setup_btn_capture"
            android:textColor="@color/vf_background" />

        <Button
            android:id="@+id/btnBackground"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/vf_card"
            android:text="@string/setup_btn_background"
            android:textColor="@color/vf_text" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="@string/setup_background_hint"
            android:textColor="@color/vf_text_muted"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@color/vf_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/update_section_title"
                android:textColor="@color/vf_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAppVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/vf_text_muted"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/update_auto_check"
                android:textColor="@color/vf_text"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/update_auto_check_hint"
                android:textColor="@color/vf_text_muted"
                android:textSize="12sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchAutoCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:checked="true" />

            <Button
                android:id="@+id/btnCheckUpdates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/vf_primary"
                android:text="@string/update_check_now"
                android:textColor="@color/vf_background" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/setup_hint_amap"
            android:textColor="@color/vf_text_muted"
            android:textSize="11sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="@string/setup_hint_yandex"
            android:textColor="@color/vf_text_muted"
            android:textSize="11sp" />

    </LinearLayout>
</ScrollView>
